# ── Anthropic (caption generation + eval judge) ──
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Google Cloud ──
# Path to your service account JSON key file (NOT committed — see .gitignore)
GOOGLE_APPLICATION_CREDENTIALS=./ayurpost-XXXXXXXXXXXX.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Document AI (OCR — already used for Sushruta)
DOC_AI_LOCATION=asia-south1
DOC_AI_PROCESSOR_ID=your-processor-id

# Embedding model — Voyage AI voyage-3-large (32K window, top multilingual)
VOYAGE_API_KEY=your-voyage-api-key
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024

# Image generation model — see config.py for options
IMAGE_MODEL=gemini-2.5-flash-image

# Text-to-Speech voices (English-Indian + Kannada)
TTS_VOICE_EN=en-IN-Wavenet-D
TTS_VOICE_KN=kn-IN-Wavenet-A

# ── Qdrant Cloud (vector DB) ──
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ── OpenWeatherMap (current weather for roadmap engine) ──
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ── Clinic config ──
CLINIC_CITY=Bengaluru
CLINIC_COUNTRY_CODE=IN
